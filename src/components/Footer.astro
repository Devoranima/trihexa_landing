---
const year = new Date().getFullYear();

const links = {
  'Продукция': [
    { text: 'Автоковрики', href: '/car' },
    { text: 'Домашние коврики', href: '/home' },
    { text: 'Гаражные системы', href: '/garage' },
  ],
  // 'Компания': [
  //   { text: 'О нас', href: '#' },
  //   { text: 'Гарантия качества', href: '#' },
  //   { text: 'Вакансии', href: '#' },
  // ],
  'Контакты': [
    { text: 'info@trihexa.com', href: 'mailto:info@trihexa.com' },
    { text: '+7 (999) 123-45-67', href: 'tel:+79991234567' },
    { text: 'Запросить цену', href: '/#contact' },
  ],
};
---

<footer class="bg-[#0c0c0d] border-t border-th-red/15">
  <!-- top section -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-16 lg:py-20">
    <div class="grid lg:grid-cols-[1fr_2fr] gap-14 lg:gap-24">

      <!-- brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-6 group w-fit">
          <img src="/ICON.svg" alt="TriHexa" class="w-10 h-10 transition-transform duration-300 group-hover:scale-110" />
          <span class="font-display text-[1.7rem] text-th-white tracking-[0.22em] leading-none">TRIHEXA</span>
        </a>
        <p class="text-th-light/35 text-sm leading-relaxed max-w-[30ch]">
          Производство ковриков для автомобилей, дома и гаража. Качество в каждой детали.
        </p>
        <div class="flex items-center gap-4 mt-8">
          <span class="block w-8 h-px bg-th-red"></span>
          <span class="text-th-light/35 text-[0.6rem] tracking-[0.4em] uppercase">Est. 2020</span>
        </div>
      </div>

      <!-- links grid -->
      <div class="grid sm:grid-cols-3 gap-10">
        {Object.entries(links).map(([group, items]) => (
          <div>
            <div class="text-th-light/25 text-[0.6rem] tracking-[0.45em] uppercase mb-5">{group}</div>
            <ul class="space-y-3">
              {items.map(item => (
                <li>
                  <a
                    href={item.href}
                    class="text-th-light/50 hover:text-th-red text-sm transition-colors duration-200"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- bottom bar -->
  <div class="border-t border-th-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-th-light/20 text-[0.65rem] tracking-[0.3em]">
        &copy; {year} TRiHEXA. Все права защищены.
      </span>
      <div class="flex items-center gap-6">
        {[
          { text: 'Политика конфиденциальности', href: '/privacy' },
          { text: 'Условия использования', href: '/terms' },
        ].map(l => (
          <a href={l.href} class="text-th-light/20 hover:text-th-light/50 text-[0.65rem] tracking-[0.25em] uppercase transition-colors duration-200">
            {l.text}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
