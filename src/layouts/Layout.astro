---
interface Props {
  title: string;
  description?: string;
}

const SITE = 'https://trihexa.ru';

const {
  title,
  description = 'TriHexa — Производство ковриков для автомобилей, дома и гаража. Качество в каждой детали.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE).href;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#A80000" />
    <link rel="icon" type="image/svg+xml" href="/ICON.svg" />
    <link rel="icon" type="image/png" href="/ICON.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="TriHexa" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${SITE}/ICON.png`} />

    <title>{title}</title>

    <!-- structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "TriHexa",
      "url": SITE,
      "logo": `${SITE}/ICON.svg`,
      "description": "Производство ковриков для автомобилей, дома и гаража",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "ceo@trihexapro.ru",
        "telephone": "+7-906-328-33-28",
        "contactType": "sales",
        "availableLanguage": "Russian"
      }
    })} />

    <!-- fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@200..700&&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
