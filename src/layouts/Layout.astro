---
interface Props {
  title: string;
  description?: string;
}

const SITE = 'https://trihexa.ru';

const {
  title,
  description = 'TRiHEXA — Производство ковриков для автомобилей, дома и гаража. Качество в каждой детали.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE).href;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#A80000" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="TRiHEXA" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="TRiHEXA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${SITE}/og-image.jpg`} />

    <!-- Twitter -->
    <meta name="twitter:card" content={`${SITE}/og-image.jpg`} />
    <meta name="twitter:title" content="TRiHEXA" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/og-image.jpg`} />

    <title>{title}</title>

    <!-- structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "TriHexa",
      "url": SITE,
      "logo": `${SITE}/ICON.svg`,
      "description": "Производство ковриков для автомобилей, дома и гаража",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "ceo@trihexa.ru",
        "telephone": "+7-906-328-33-28",
        "contactType": "sales",
        "availableLanguage": "Russian"
      }
    })} />

    <!-- fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@200..700&&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="scroller">
      <slot />
    </div>
    <script>
      // Handle anchor links since #scroller is the scroll container, not the viewport
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a[href*="#"]');
        if (!link) return;
        const href = link.getAttribute('href');
        if (!href) return;
        const hash = href.includes('#') ? href.split('#')[1] : null;
        if (!hash) return;
        const target = document.getElementById(hash);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
        history.pushState(null, '', `#${hash}`);
      });
    </script>
  </body>
</html>
